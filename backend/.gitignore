# ──────────────────────────────────────────────────────────
# 파이썬 및 FastAPI 백엔드 프로젝트 .gitignore 설정
# ──────────────────────────────────────────────────────────

# 1. 가상환경 (용량이 크고 컴퓨터마다 환경이 달라 절대 올리면 안 됨)
venv/
.venv/
env/
ENV/

# 2. 운영체제 및 IDE 설정 파일 (작업 환경 찌꺼기)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.DS_Store
Thumbs.db

# 3. 파이썬 실행 중 생성되는 컴파일 캐시 파일
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/

# 4. 보안 및 환경 변수 파일 (DB 비밀번호, API 키 등이 들어있으므로 절대 금지 🚨)
.env
.env.local
.env.*.local
wallet/
**/wallet/

# 5. 데이터베이스 및 로그 파일 (로컬 테스트용 찌꺼기 배제)
*.db
*.sqlite3
*.log
logs/
data/
